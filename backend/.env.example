# JanVedha AI Backend Environment Variables
# Copy this file to .env and fill in your values

# ─── Database (Required) ─────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/janvedha?retryWrites=true&w=majority

# ─── Security (Required) ─────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars

# ─── Environment ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
# Options: development, staging, production

# ─── City Configuration ──────────────────────────────────────────────────────
CITY_NAME=Chennai
TOTAL_WARDS=200

# ─── AI Services (Required for AI features) ──────────────────────────────────
GEMINI_API_KEY=your-google-gemini-api-key

# ─── Notifications (Optional) ────────────────────────────────────────────────
# Twilio for SMS
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=

# Email via SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Telegram Bot
TELEGRAM_BOT_TOKEN=

# ─── File Storage (Optional) ─────────────────────────────────────────────────
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ─── CORS Configuration ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins (leave empty to allow all)
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend-domain.com
